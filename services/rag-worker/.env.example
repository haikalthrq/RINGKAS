DATABASE_URL=postgresql://ringkas:change-me-locally@localhost:5432/ringkas
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
# Setup-only; required by ringkas-qdrant-setup, not ordinary worker startup.
QDRANT_COLLECTION_NAME=ringkas_chunks_v1
QDRANT_DENSE_VECTOR_SIZE=
DENSE_TOP_K=20
SPARSE_TOP_K=20
RRF_K=60
FINAL_TOP_K=10
QDRANT_DENSE_DISTANCE=
NVIDIA_NIM_API_KEY=
# Required only when constructing the embedding client; no provider/model fallback.
NVIDIA_NIM_EMBEDDING_MODEL=
# Service origin or /v1 API root; the client appends exactly /embeddings.
NVIDIA_NIM_BASE_URL=
NVIDIA_NIM_EMBEDDING_CONNECT_TIMEOUT_SECONDS=10
NVIDIA_NIM_EMBEDDING_READ_TIMEOUT_SECONDS=60
PDF_STORAGE_PATH=/data/ringkas/pdfs
PDF_MAX_SIZE_BYTES=52428800
PDF_CONNECT_TIMEOUT_SECONDS=10
PDF_READ_TIMEOUT_SECONDS=60
PDF_MAX_REDIRECTS=5
# Comma-separated exact hosts or subdomains, required for PDF downloads.
PDF_ALLOWED_HOSTS=
BPS_API_KEY=
BPS_BASE_URL=
BPS_PUBLICATIONS_PATH=
INGESTION_POLL_INTERVAL_SECONDS=10
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
CHUNK_SIZE_MIN=500
CHUNK_SIZE_MAX=800
CHUNK_OVERLAP_PERCENT=20
OCR_ENABLED=false
# Developer-only retrieval diagnostics; disabled unless explicitly enabled.
RETRIEVAL_DEBUG_LOG_ENABLED=false
# Query and textual filter previews require explicit developer opt-in.
RETRIEVAL_DEBUG_INCLUDE_SENSITIVE_TEXT=false
# Scores are developer-only and are never user-facing.
RETRIEVAL_DEBUG_INCLUDE_SCORES=false
RETRIEVAL_DEBUG_QUERY_MAX_CHARS=128
RETRIEVAL_DEBUG_MAX_CANDIDATES=20
