DATABASE_URL=postgresql://ringkas:change-me-locally@localhost:5432/ringkas
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
# Versioned collection for the approved Cloudflare embedding model. Do not mix
# vectors from another provider/model in this collection.
QDRANT_COLLECTION_NAME=ringkas_chunks_cf_qwen3_embedding_v2
# Live-verified for @cf/qwen/qwen3-embedding-0.6b. Reverify before changing models.
QDRANT_DENSE_VECTOR_SIZE=1024
DENSE_TOP_K=20
SPARSE_TOP_K=20
RRF_K=60
FINAL_TOP_K=10
QDRANT_DENSE_DISTANCE=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKERS_AI_EMBEDDING_MODEL=@cf/qwen/qwen3-embedding-0.6b
CLOUDFLARE_WORKERS_AI_EMBEDDING_CONNECT_TIMEOUT_SECONDS=10
CLOUDFLARE_WORKERS_AI_EMBEDDING_READ_TIMEOUT_SECONDS=60
PDF_STORAGE_PATH=/data/ringkas/pdfs
PDF_MAX_SIZE_BYTES=52428800
PDF_CONNECT_TIMEOUT_SECONDS=10
PDF_READ_TIMEOUT_SECONDS=60
PDF_TOTAL_TIMEOUT_SECONDS=300
PDF_MAX_REDIRECTS=5
# Comma-separated exact hosts or subdomains, required for PDF downloads.
PDF_ALLOWED_HOSTS=
BPS_API_KEY=
BPS_BASE_URL=https://webapi.bps.go.id/v1/api/list
BPS_PUBLICATIONS_PATH=
BPS_PUBLICATION_KEYWORD=
INGESTION_POLL_INTERVAL_SECONDS=10
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
CHUNK_SIZE_MIN=500
CHUNK_SIZE_MAX=800
CHUNK_OVERLAP_PERCENT=20
OCR_ENABLED=false
# Developer-only retrieval diagnostics; disabled unless explicitly enabled.
RETRIEVAL_DEBUG_LOG_ENABLED=false
# Query and textual filter previews require explicit developer opt-in.
RETRIEVAL_DEBUG_INCLUDE_SENSITIVE_TEXT=false
# Scores are developer-only and are never user-facing.
RETRIEVAL_DEBUG_INCLUDE_SCORES=false
RETRIEVAL_DEBUG_QUERY_MAX_CHARS=128
RETRIEVAL_DEBUG_MAX_CANDIDATES=20
