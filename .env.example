ASPNETCORE_ENVIRONMENT=Development
WEB_PORT=3000
DATABASE_URL=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_GENERATION_MODEL=nvidia/nemotron-3-nano-30b-a3b
