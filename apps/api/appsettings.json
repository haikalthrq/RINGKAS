{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RateLimits": {
    "Auth": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "Chat": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    },
    "AdminIngestion": {
      "PermitLimit": 3,
      "WindowSeconds": 60
    }
  },
  "GUEST_PROMPT_QUOTA": "1",
  "REGISTERED_DAILY_QUOTA": "",
  "AllowedHosts": "*"
}
